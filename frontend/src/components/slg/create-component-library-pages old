#!/usr/bin/env python3
import subprocess
import os
import argparse
from argparse import RawTextHelpFormatter
from logger_slg import init_logger


def get_arguments():
    parser = argparse.ArgumentParser(description='', formatter_class=RawTextHelpFormatter)

    # argument groups can have their tickers combined (ie -su)
    bools = parser.add_argument_group()

    parser.add_argument('-i', '--input_directory', required=True,
                help='Use absolute paths when specifying the input directory.')

    parser.add_argument('-o', '--output_directory', required=True,
                help='The outermost output directory')

    args = parser.parse_args()

    return args

def extract_component_types(filepath):
    with open(filepath, 'r') as f:
        lines = f.readlines()
        for line in lines:
            if "export let componentType" in line:
                return [el.strip() for el in line.split('//')[1].split(',')]
    return []

def build_all_component_type_strings(component_types, component_name, tabs=2):
    tab_size = '\t' * tabs
    if len(component_types) == 0:
        return f'''{tab_size}<div class="pt-4 pb-4">
{tab_size}\t<p class="mx-8 text-gray-600 text-sm">&lt;{component_name} /&gt;
{tab_size}\t<div class="px-6 py-4 bg-2 mx-8 rounded-lg shadow-1">
{tab_size}\t\t<{component_name} example=true />
{tab_size}\t</div>
{tab_size}</div>'''

    string = ''
    for component_type in component_types:
        string += f'''{tab_size}<div class="pt-4 pb-4">
{tab_size}\t<p class="mx-8 text-gray-600 text-sm">&lt;{component_name} componentType=&quot;{component_type}&quot; /&gt;
{tab_size}\t<div class="px-6 py-4 bg-2 mx-8 rounded-lg shadow-1">
{tab_size}\t\t<{component_name} componentType={{"{component_type}"}} example=true />
{tab_size}\t</div>
{tab_size}</div>'''
    return string


