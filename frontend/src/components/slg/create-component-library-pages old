{build_all_component_type_strings(extract_component_types(component_dir), component_name, tabs=2)}
    </div>

    <div slot="right">

    </div>
</NamedSlotLayout>
'''

def generate_example_usage(filepath, component_name):

    def get_example_lines(lines):
        open_if_statement = "{#if example}"
        # else has to exist at the start of the line. Then in that block we will search for svelteself
        for idx, line in enumerate(lines):
            if line.startswith(open_if_statement):
                i = idx
                print(idx)

        if not i:
            return None

        for idx, line in enumerate(lines):
            if line.startswith('{:else}'):
                j = idx
                print(idx)

        return lines[i+1:j]

    def replace_self_block_with_name(lines, replacement=component_name):
        replaced_open = False
        new_lines = []
        for line in lines:
            if "svelte:self" in line and not replaced_open:
                new_lines.append(line.replace("svelte:self", replacement))
                replaced_open = True
            else:
                new_lines.append(line)

        # once thats iterated over we'll look for the back svelte:self entry
        new_new_lines = []
        replaced_close = False
        for line in new_lines[::-1]:
            if "/svelte:self" in line and not replaced_close:
                new_new_lines.append(line.replace("svelte:self", replacement))
                replaced_close = True
            else:
                new_new_lines.append(line)

        return ''.join(new_new_lines[::-1])


    with open(filepath, 'r') as f:
        # extract the svelte:self block inside of the {#if example} ... {:else} block
        lines = f.readlines()
        example_lines = get_example_lines(lines)

        if example_lines:
            return replace_self_block_with_name(lines, component_name)
        else:
            return f'<{component_name} />'



